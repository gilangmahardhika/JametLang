{
  "Variable Declaration": {
    "prefix": "variabel",
    "body": ["variabel ${1:nama} = ${2:nilai};"],
    "description": "Deklarasi variabel (variable declaration)"
  },
  "Print": {
    "prefix": "nyerat",
    "body": ["nyerat(${1:\"pesan\"});"],
    "description": "Nyerat output (print)"
  },
  "Read Input": {
    "prefix": "moco",
    "body": ["variabel ${1:input} = moco();"],
    "description": "Moco input (read input)"
  },
  "If Statement": {
    "prefix": "nek",
    "body": [
      "nek (${1:kondisi}) {",
      "\t${2:// kode}",
      "}"
    ],
    "description": "Kondisi nek (if statement)"
  },
  "If-Else Statement": {
    "prefix": "nekkajaba",
    "body": [
      "nek (${1:kondisi}) {",
      "\t${2:// kode nek bener}",
      "} kajaba {",
      "\t${3:// kode nek salah}",
      "}"
    ],
    "description": "Kondisi nek-kajaba (if-else statement)"
  },
  "For Loop": {
    "prefix": "kanggo",
    "body": [
      "kanggo (variabel ${1:i} = ${2:0}; ${1:i} < ${3:10}; ${1:i} = ${1:i} + 1) {",
      "\t${4:// kode}",
      "}"
    ],
    "description": "Loop kanggo (for loop)"
  },
  "While Loop": {
    "prefix": "sawise",
    "body": [
      "sawise (${1:kondisi}) {",
      "\t${2:// kode}",
      "}"
    ],
    "description": "Loop sawise (while loop)"
  },
  "Function Declaration": {
    "prefix": "fungsi",
    "body": [
      "fungsi ${1:nama}(${2:params}) {",
      "\t${3:// kode}",
      "\tbalekno ${4:nilai};",
      "}"
    ],
    "description": "Deklarasi fungsi (function declaration)"
  },
  "Return": {
    "prefix": "balekno",
    "body": ["balekno ${1:nilai};"],
    "description": "Balekno nilai (return value)"
  },
  "Break": {
    "prefix": "pegat",
    "body": ["pegat;"],
    "description": "Pegat loop (break)"
  },
  "Continue": {
    "prefix": "terusake",
    "body": ["terusake;"],
    "description": "Terusake loop (continue)"
  },
  "Block Comment": {
    "prefix": "komentar",
    "body": [
      "/* ${1:komentar} */"
    ],
    "description": "Komentar blok (block comment)"
  },
  "String Length": {
    "prefix": "panjang",
    "body": ["panjang(${1:str})"],
    "description": "Panjang string/array"
  },
  "Substring": {
    "prefix": "potong",
    "body": ["potong(${1:str}, ${2:mulai}, ${3:akhir})"],
    "description": "Potong substring"
  },
  "Uppercase": {
    "prefix": "huruf_gedhe",
    "body": ["huruf_gedhe(${1:str})"],
    "description": "Huruf gedhe (uppercase)"
  },
  "Lowercase": {
    "prefix": "huruf_cilik",
    "body": ["huruf_cilik(${1:str})"],
    "description": "Huruf cilik (lowercase)"
  },
  "Replace": {
    "prefix": "ganti",
    "body": ["ganti(${1:str}, ${2:lama}, ${3:anyar})"],
    "description": "Ganti substring (replace)"
  },
  "Contains": {
    "prefix": "ngandhut",
    "body": ["ngandhut(${1:str}, ${2:sub})"],
    "description": "Cek ngandhut substring (contains)"
  },
  "Split": {
    "prefix": "pisah",
    "body": ["pisah(${1:str}, ${2:delimiter})"],
    "description": "Pisah string dadi array (split)"
  },
  "Absolute": {
    "prefix": "mutlak",
    "body": ["mutlak(${1:n})"],
    "description": "Nilai mutlak (absolute value)"
  },
  "Power": {
    "prefix": "pangkat",
    "body": ["pangkat(${1:base}, ${2:exp})"],
    "description": "Pangkat (power)"
  },
  "Square Root": {
    "prefix": "akar",
    "body": ["akar(${1:n})"],
    "description": "Akar kuadrat (square root)"
  },
  "Random": {
    "prefix": "acak",
    "body": ["acak(${1:min}, ${2:max})"],
    "description": "Angka acak (random)"
  },
  "Round": {
    "prefix": "bulatke",
    "body": ["bulatke(${1:n})"],
    "description": "Bulatke (round)"
  },
  "Floor": {
    "prefix": "lantai",
    "body": ["lantai(${1:n})"],
    "description": "Lantai (floor)"
  },
  "Ceil": {
    "prefix": "langit",
    "body": ["langit(${1:n})"],
    "description": "Langit-langit (ceil)"
  },
  "To Integer": {
    "prefix": "dadi_angka",
    "body": ["dadi_angka(${1:val})"],
    "description": "Konversi dadi integer"
  },
  "To Float": {
    "prefix": "dadi_desimal",
    "body": ["dadi_desimal(${1:val})"],
    "description": "Konversi dadi float"
  },
  "To String": {
    "prefix": "dadi_teks",
    "body": ["dadi_teks(${1:val})"],
    "description": "Konversi dadi string"
  },
  "Type Name": {
    "prefix": "jinis",
    "body": ["jinis(${1:val})"],
    "description": "Entuk jeneng jinis (type name)"
  },
  "Current Time": {
    "prefix": "wektu",
    "body": ["wektu()"],
    "description": "Wektu saiki (current time in seconds)"
  },
  "Array Literal": {
    "prefix": "array",
    "body": ["[${1:elements}]"],
    "description": "Array literal"
  },
  "Array Push": {
    "prefix": "tambah",
    "body": ["tambah(${1:arr}, ${2:elem})"],
    "description": "Tambah elemen ing mburi array (push)"
  },
  "Array Remove": {
    "prefix": "hapus",
    "body": ["hapus(${1:arr}, ${2:indeks})"],
    "description": "Hapus elemen ing indeks (remove)"
  },
  "Array Concat": {
    "prefix": "gabung",
    "body": ["gabung(${1:arr1}, ${2:arr2})"],
    "description": "Gabung loro array (concat)"
  },
  "Array Reverse": {
    "prefix": "balik",
    "body": ["balik(${1:arr})"],
    "description": "Balik urutan array (reverse)"
  },
  "Array Sort": {
    "prefix": "urutke",
    "body": ["urutke(${1:arr})"],
    "description": "Urutke array ascending (sort)"
  },
  "Array Slice": {
    "prefix": "irisan",
    "body": ["irisan(${1:arr}, ${2:mulai}, ${3:akhir})"],
    "description": "Potong array (slice)"
  },
  "Array IndexOf": {
    "prefix": "indeks",
    "body": ["indeks(${1:arr}, ${2:val})"],
    "description": "Golek indeks elemen ing array (indexOf)"
  },
  "Try Catch": {
    "prefix": "jancuk",
    "body": [
      "jancuk {",
      "\t${1:// kode sing bisa error}",
      "} awas (${2:err}) {",
      "\t${3:// tangani error}",
      "}"
    ],
    "description": "Try/catch block (jancuk/awas)"
  },
  "Try Catch Finally": {
    "prefix": "jancuk-rampungke",
    "body": [
      "jancuk {",
      "\t${1:// kode sing bisa error}",
      "} awas (${2:err}) {",
      "\t${3:// tangani error}",
      "} rampungke {",
      "\t${4:// tansah dieksekusi}",
      "}"
    ],
    "description": "Try/catch/finally block (jancuk/awas/rampungke)"
  },
  "Throw": {
    "prefix": "uncal",
    "body": ["uncal ${1:\"pesan error\"};"],
    "description": "Throw exception (uncal)"
  },
  "ForEach": {
    "prefix": "saben",
    "body": [
      "saben (variabel ${1:item} : ${2:array}) {",
      "\t${3:// body}",
      "}"
    ],
    "description": "forEach loop (saben)"
  },
  "Lambda": {
    "prefix": "lambda",
    "body": [
      "variabel ${1:fn} = fungsi(${2:x}) {",
      "\tbalekno ${3:x * 2};",
      "};"
    ],
    "description": "Lambda/anonymous function"
  },
  "Map Literal": {
    "prefix": "map",
    "body": [
      "variabel ${1:data} = {",
      "\t\"${2:key}\": ${3:value}",
      "};"
    ],
    "description": "Map/dictionary literal"
  },
  "Read File": {
    "prefix": "baca_file",
    "body": ["variabel ${1:isi} = baca_file(${2:\"path.txt\"});"],
    "description": "Read file contents"
  },
  "Write File": {
    "prefix": "tulis_file",
    "body": ["tulis_file(${1:\"path.txt\"}, ${2:\"content\"});"],
    "description": "Write to file"
  },
  "Append File": {
    "prefix": "tambah_file",
    "body": ["tambah_file(${1:\"path.txt\"}, ${2:\"content\"});"],
    "description": "Append to file"
  },
  "File Exists": {
    "prefix": "ana_file",
    "body": ["ana_file(${1:\"path.txt\"})"],
    "description": "Check if file exists"
  },
  "HTTP GET": {
    "prefix": "http_get",
    "body": ["variabel ${1:response} = http_get(${2:\"https://api.example.com\"});"],
    "description": "HTTP GET request"
  },
  "HTTP POST": {
    "prefix": "http_post",
    "body": ["variabel ${1:response} = http_post(${2:\"https://api.example.com\"}, ${3:data}, ${4:\"application/json\"});"],
    "description": "HTTP POST request"
  },
  "Import Module": {
    "prefix": "jupuk",
    "body": ["jupuk \"${1:module.jmt}\";"],
    "description": "Import module (jupuk)"
  },
  "Export Function": {
    "prefix": "kirim",
    "body": [
      "kirim fungsi ${1:name}(${2:params}) {",
      "\t${3:// body}",
      "}"
    ],
    "description": "Export function (kirim)"
  },
  "Map Keys": {
    "prefix": "kunci_map",
    "body": ["kunci_map(${1:map})"],
    "description": "Get all map keys"
  },
  "Map Has Key": {
    "prefix": "ana_kunci",
    "body": ["ana_kunci(${1:map}, ${2:\"key\"})"],
    "description": "Check if map has key"
  },
  "Current Date": {
    "prefix": "tanggal_saiki",
    "body": ["variabel ${1:saiki} = tanggal_saiki();"],
    "description": "Get current date as map"
  },
  "Format Date": {
    "prefix": "format_tanggal",
    "body": ["format_tanggal(${1:\"%Y-%m-%d %H:%M:%S\"})"],
    "description": "Format date with strftime"
  },
  "Parse Date": {
    "prefix": "parsing_tanggal",
    "body": ["parsing_tanggal(${1:\"2025-01-15\"}, ${2:\"%Y-%m-%d\"})"],
    "description": "Parse date string to timestamp"
  },
  "Sleep": {
    "prefix": "turu",
    "body": ["turu(${1:1000});"],
    "description": "Sleep for milliseconds"
  },
  "Hash SHA256": {
    "prefix": "hash_sha256",
    "body": ["variabel ${1:hash} = hash_sha256(${2:\"data\"});"],
    "description": "SHA256 hash"
  },
  "HMAC SHA256": {
    "prefix": "hmac_sha256",
    "body": ["variabel ${1:hmac} = hmac_sha256(${2:\"key\"}, ${3:\"data\"});"],
    "description": "HMAC-SHA256"
  },
  "Base64 Encode": {
    "prefix": "base64_encode",
    "body": ["base64_encode(${1:\"data\"})"],
    "description": "Base64 encode string"
  },
  "Base64 Decode": {
    "prefix": "base64_decode",
    "body": ["base64_decode(${1:\"encoded\"})"],
    "description": "Base64 decode string"
  },
  "JSON Parse": {
    "prefix": "json_parsing",
    "body": ["variabel ${1:obj} = json_parsing(${2:json_str});"],
    "description": "Parse JSON string to value"
  },
  "JSON Format": {
    "prefix": "json_format",
    "body": ["variabel ${1:str} = json_format(${2:value});"],
    "description": "Format value to JSON string"
  },
  "CSV Parse": {
    "prefix": "csv_parsing",
    "body": ["variabel ${1:rows} = csv_parsing(${2:csv_str});"],
    "description": "Parse CSV string to array"
  },
  "CSV Format": {
    "prefix": "csv_format",
    "body": ["variabel ${1:str} = csv_format(${2:data});"],
    "description": "Format array to CSV string"
  },
  "TCP Connect": {
    "prefix": "soket_tcp",
    "body": ["variabel ${1:fd} = soket_tcp(${2:\"localhost\"}, ${3:8080});"],
    "description": "Connect TCP socket"
  },
  "TCP Server": {
    "prefix": "soket_server",
    "body": ["variabel ${1:server} = soket_server(${2:8080});"],
    "description": "Create TCP server socket"
  },
  "Socket Send": {
    "prefix": "soket_kirim",
    "body": ["soket_kirim(${1:fd}, ${2:\"data\"});"],
    "description": "Send data on socket"
  },
  "Socket Receive": {
    "prefix": "soket_tampa",
    "body": ["variabel ${1:data} = soket_tampa(${2:fd});"],
    "description": "Receive data from socket"
  },
  "Socket Close": {
    "prefix": "soket_tutup",
    "body": ["soket_tutup(${1:fd});"],
    "description": "Close socket"
  },
  "Log Info": {
    "prefix": "catat",
    "body": ["catat(${1:\"pesan\"});"],
    "description": "Log info message with timestamp"
  },
  "Log Warning": {
    "prefix": "catat_peringatan",
    "body": ["catat_peringatan(${1:\"pesan\"});"],
    "description": "Log warning message"
  },
  "Log Error": {
    "prefix": "catat_galat",
    "body": ["catat_galat(${1:\"pesan\"});"],
    "description": "Log error message"
  },
  "Log Debug": {
    "prefix": "catat_debug",
    "body": ["catat_debug(${1:\"pesan\"});"],
    "description": "Log debug message"
  },
  "Log to File": {
    "prefix": "catat_ke_file",
    "body": ["catat_ke_file(${1:\"app.log\"}, ${2:\"pesan\"});"],
    "description": "Log message to file"
  },
  "Regex Match": {
    "prefix": "regex_cocok",
    "body": ["regex_cocok(${1:\"pola\"}, ${2:\"teks\"})"],
    "description": "Test regex match (boolean)"
  },
  "Regex Find": {
    "prefix": "regex_golek",
    "body": ["regex_golek(${1:\"pola\"}, ${2:\"teks\"})"],
    "description": "Find first regex match"
  },
  "Regex Find All": {
    "prefix": "regex_golek_kabeh",
    "body": ["regex_golek_kabeh(${1:\"pola\"}, ${2:\"teks\"})"],
    "description": "Find all regex matches"
  },
  "Regex Replace": {
    "prefix": "regex_ganti",
    "body": ["regex_ganti(${1:\"pola\"}, ${2:\"teks\"}, ${3:\"pengganti\"})"],
    "description": "Replace all regex matches"
  },
  "Regex Split": {
    "prefix": "regex_pisah",
    "body": ["regex_pisah(${1:\"pola\"}, ${2:\"teks\"})"],
    "description": "Split text by regex pattern"
  },
  "Get Env": {
    "prefix": "env_njupuk",
    "body": ["variabel ${1:val} = env_njupuk(${2:\"HOME\"});"],
    "description": "Get environment variable"
  },
  "Set Env": {
    "prefix": "env_setel",
    "body": ["env_setel(${1:\"KEY\"}, ${2:\"value\"});"],
    "description": "Set environment variable"
  },
  "Run Command": {
    "prefix": "jalan_perintah",
    "body": ["variabel ${1:output} = jalan_perintah(${2:\"ls -la\"});"],
    "description": "Execute shell command and get output"
  },
  "Exit": {
    "prefix": "keluar",
    "body": ["keluar(${1:0});"],
    "description": "Exit program with code"
  },
  "Current Directory": {
    "prefix": "direktori_saiki",
    "body": ["variabel ${1:cwd} = direktori_saiki();"],
    "description": "Get current working directory"
  }
}
